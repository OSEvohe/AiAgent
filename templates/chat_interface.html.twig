{% extends 'base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('/styles.css') }}">
{% endblock %}

{% block body %}
    <div class="chat-container">
        <header class="chat-header">
            <h1>AI Chat</h1>
            <div class="header-buttons">
                <button class="settings-btn">⚙️</button>&#x1f600;
            </div>
        </header>
        <main class="chat-main">
            <aside class="discussion-list">
                <button class="new-discussion-btn">New Discussion</button>
                <!-- Discussion items will be added here -->
            </aside>
            <section class="message-area" id="chatMessages">
                {{ component('MessageAreaComponent') }}
            </section>
        </main>
           {{ component('InputAreaComponent') }}
    </div>
{% endblock %}