<section data-action="scroll->message-area#scrolling" data-message-area-target="messageArea" class="message-area py-5 px-3" id="chatMessages"
         style="position: relative" {{ attributes.defaults(stimulus_controller('message-area')) }} data-poll="delay(500)|$render">
    {% for entry in this.messages %}
        {% if entry.data.role == 'assistant' and entry.data.tool_calls is defined and entry.data.tool_calls|length > 0 %}
            <div class="row">
                <div class="col-sm-12 col-xl-7 offset-xl-2">
                    <div class="message-wrapper ai-message-wrapper float-start">
                        <div class="message tool-message" data-live-ignore>
                            <span title="{{ entry.data.tool_calls[0].function.arguments }}"><strong>&#x1F6E0;</strong> {{ entry.data.tool_calls[0].function.name }}</span>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}

        {% if entry.data.role == 'user' %}
            <div class="row" data-skip-morph>
                <div class="col-sm-12 col-xl-7 offset-xl-4 text-right">
                    <div class="message-wrapper user-message-wrapper float-end">
                        <div class="message user-message" data-live-ignore>
                            {{ this.markdown(entry.data.content)|raw }}
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}

        {% if entry.data.role == 'assistant' and entry.data.content is not null and entry.agentId == 'coding_agent' %}
            <div class="row" data-skip-morph>
                <div class="col-sm-12 col-xl-7 offset-xl-1">
                    <div class="message-wrapper ai-message-wrapper float-start">
                        <div class="message ai-message">
                            {% if entry.data.content == 'Processing...' %}
                                <span class="spinner-border">{{ ux_icon('gg:spinner') }}</span>
                            {% else %}
                                {{ this.markdown(entry.data.content)|raw }}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    {% endfor %}
    <button data-message-area-target="scrollToBottomButton" class="d-none" data-action="click->message-area#scrollToBottom" id="scroll-to-bottom"
            style="position: fixed; bottom: 20vh ; right: 20px; background: #000; border-radius: 50%; padding: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.3);">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
    </button>
</section>
